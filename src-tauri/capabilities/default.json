{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-app-read",
    "fs:allow-app-write",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "$HOME/.config/heimdall/**" }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "$HOME/.config/heimdall/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$HOME/.config/heimdall/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$HOME/.config/heimdall/**" }]
    }
  ]
}
